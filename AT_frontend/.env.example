# Atticus mobile demo — environment variables
#
# IMPORTANT: any variable prefixed with VITE_ is baked into the production
# JavaScript bundle and is therefore PUBLIC. Do not put a secret here that you
# would not be comfortable pasting into a public Pastebin. The runtime-pasted
# Bybit credentials path on the admin diagnostic page is the recommended way
# to test signed Bybit reads — keys entered there live in memory only.

# Optional: prefill the Bybit diagnostic inputs from env (NOT recommended for
# real keys; convenience for throwaway testnet keys only).
# VITE_BYBIT_API_KEY=
# VITE_BYBIT_API_SECRET=

# Bybit base URL toggle. "true" → api-testnet.bybit.com, "false" → api.bybit.com.
# Defaults to mainnet because mainnet keys do not authenticate against testnet.
VITE_BYBIT_TESTNET=false

# Geo-fence configuration (defence-in-depth on top of partner KYC).
# VITE_GEOFENCE_DENY=IR,KP,RU
# VITE_GEOFENCE_ALLOW_ONLY=
